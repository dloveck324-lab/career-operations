node_modules/
dist/
apps/web/dist/
apps/server/dist/

# Local SQLite — never committed
data/*.db
data/*.db-shm
data/*.db-wal

# Environment / secrets
.env
.env.*
!.env.example

# Personal data — only the *.example.* templates are committed.
# See CLAUDE.md → Workflow Rules → Personal data.
config/profile.yml
config/cv.md
config/cv.pdf
config/resume.pdf
config/filters.yml
config/*.local.*

# Variant CVs and profile overlays (personal data, never committed).
# Code expects loadCv('healthcare') -> config/cv-healthcare.md, etc.
config/cv-*.md
config/cv-*.pdf
config/profile-*.yml

# One-shot migration script (delete after running)
/finalize-renderer-migration.sh

# OS / editor cruft
.DS_Store
*.log
.vscode/
.idea/
